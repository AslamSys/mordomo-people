# mordomo-people — Environment Variables
# Copie para .env e preencha

# NATS
NATS_URL=nats://nats:4222

# PostgreSQL (use a URL do container da infra)
DATABASE_URL=postgresql://aslam:TROQUE_ISSO@postgres:5432/aslam

# Redis (db 0 reservado para mordomo-people)
REDIS_URL=redis://redis:6379/0

# Chave mestre AES-256 para criptografia de dados sensíveis.
# Gere com: python -c "import os,binascii; print(binascii.hexlify(os.urandom(32)).decode())"
PEOPLE_MASTER_KEY=

# TTL de cache em segundos (opcional)
RESOLVE_CACHE_TTL=300
PERMISSIONS_CACHE_TTL=60
